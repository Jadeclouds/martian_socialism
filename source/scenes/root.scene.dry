// array of objects of the form {date: Date(), spd: 10, kpd: 12, ...} for each election
Q.election_records = [];
// party support records for every month
Q.party_support_records = [];
// inflation and unemployment records
Q.economic_records = [];


// State of the government
Q.president = "Alexander";
// starting commissioner: Marina Yabula
Q.chancellor = "Yabula";
Q.chancellor_party = 'PEC';
Q.spm_in_government = 0;
Q.plfm_in_government = 0;
Q.ffm_in_government = 0;
Q.mlnp_in_government = 0;
Q.p_in_government = 0;
Q.pec_in_government = 1;

Q.in_marsist_coalition = 0;
Q.in_grand_marsist_coalition = 0;
Q.marsists_govern = 0;

//Party opinions regarding issues
Q.mnlp_tolerate_nondemocrats = 0;

// if you're in a coalition, this is an incremental counter for how many times dissent has happened.
Q.coalition_dissent = 0;

// ministries - which parties control the ministries?
Q.foreign_minister = 'XXX';
Q.foreign_minister_party = 'I';
Q.interior_minister = 'XXX';
Q.interior_minister_party = 'I';
Q.justice_minister = 'XXX';
Q.justice_minister_party = 'I';
Q.labor_minister = 'XXX';
Q.labor_minister_party = 'I';
Q.infrastructure_minister = 'XXX';
Q.infrastructure_minister_party = 'I';
Q.economic_minister = 'XXX';
Q.economic_minister_party = 'I';
Q.education_minister = 'XXX';
Q.education_minister_party = 'I';
Q.agriculture_minister = 'XXX';
Q.agriculture_minister_party = 'I';

// relationships with other space bodies
Q.earth_relation = 0;
Q.moon_relation = 0;
Q.asteroids_relation = 0;

// funding of other parties
Q.supported_european_socialists = 0;
Q.supported_american_socialists = 0;
Q.supported_south_socialists = 0;

// Tax statuses
Q.water_tax_status = 0;

// Advisors/Leaders
Q.n_advisors = 3;
// timer - this decrements by 1 every turn, and is set to 5 whenever an advisor action is used, so that you can only use one advisor action every 5 months.
// let's just put all of the timers here...
// most party affairs and government affairs cards are on a timer.
Q.timers = ['advisor_action', 'fundraising', 'ideology', 'inter_party_relationships', 'international_relations', 'media', 'enemies', 'party_organizations', 'rally', 'shuffle_leadership', 'party_disunity',
            // govt
             'prime_minister_policy', 'interior_policy', 'labor_policy', 'economic_policy', 'justice_policy', 'foreign_policy', 'infrastructure_policy', 'education_policy', 'agricultural_policy', 'coalition_affairs',
            // events
];
Q.advisor_action_timer = 0;
// Initialize party affairs timers
Q.advisor_action_timer = 0;
Q.fundraising_timer = 0;
Q.ideology_timer = 0;
Q.inter_party_relationships_timer = 0;
Q.international_relations_timer = 0;
Q.media_timer = 0;
Q.enemies_timer = 0;
Q.party_organizations_timer = 0;
Q.rally_timer = 0;
Q.shuffle_leadership_timer = 0;
Q.party_disunity_timer = 0;

// Initialize government policy timers
Q.prime_minister_policy_timer = 0;
Q.interior_policy_timer = 0;
Q.labor_policy_timer = 0;
Q.economic_policy_timer = 0;
Q.justice_policy_timer = 0;
Q.foreign_policy_timer = 0;
Q.infrastructure_policy_timer = 0;
Q.education_policy_timer = 0;
Q.agricultural_policy_timer = 0;
Q.coalition_affairs_timer = 0;
// elections are not on a timer, but rather there is an indicator for whether you're in an electoral cycle.
Q.in_election = 1;
Q.next_election_year = 2442;
Q.next_election_month = 7;
Q.next_election_time = 7;

// all the initial advisors are centrists.
Q.wels_advisor = 1; // Otto Wels
Q.muller_advisor = 1; // Hermann Müller
Q.muller_dead = 0;
// okay I know Arthur Crispien was a leader irl but i couldn't find much interesting about him...
Q.crispien_advisor = 0; // Arthur Crispien
Q.hilferding_advisor = 1; // Rudolf Hilferding

// left advisors
Q.sender_advisor = 0; // Toni Sender
Q.levi_advisor = 0; // Paul Levi
Q.levi_dead = 0;
Q.rosenfeld_advisor = 0; // Kurt Rosenfeld
Q.seydewitz_advisor = 0; // Max Seydewitz

// centrist alternate advisors
Q.pfulf_advisor = 0; // Antonie Pfülf
Q.breitscheid_advisor = 0; // Rudolf Breitscheid

// Reformist advisors
Q.severing_advisor = 0; // Carl Severing
Q.braun_advisor = 0; // Otto Braun
Q.juchacz_advisor = 0; // Marie Juchacz
Q.baade_advisor = 0; // Fritz Baade

// Labor advisors
Q.leipart_advisor = 0; // Theodor Leipart
Q.aufhauser_advisor = 0; // Siegfried Aufhäuser
Q.woytinsky_advisor = 0; // Wladimir Woytinsky (post-1930)
Q.wissell_advisor = 0; // Rudolf Wissell

// Revisionist advisors
