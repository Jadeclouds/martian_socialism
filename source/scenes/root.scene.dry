@start
on-arrival: {!
Q.started = 1;
// time elapsed (in months)
Q.time = 1;
Q.year = 2442;
Q.month = 1;
Q.year_mars = 169;
Q.month_mars = 1;
// how many actions have been taken this month?
Q.month_actions = 0;

// 0 = normal difficulty, 1 = hard mode, 2 = hard mode no saves
Q.difficulty = 0;
Q.historical_mode = 0;
// old demographics
Q.old_demographics = 0;
// use decimals for reichstag seats
// TODO: not yet implemented
Q.use_decimals = 0;

// party resources
Q.resources = 6;
// party dues
Q.dues = 6;

// the state of the party
// overall dissent reduces every increase in party support.
Q.dissent = 0.05;
Q.dissent_percent = 5;

// factions
Q.factions = ['left', 'progressist', 'romanticist', 'reformist' ];
Q.left_strength = 15;
Q.left_dissent = 15;
Q.progressist_strength = 30;
Q.progressist_dissent = 5;
Q.romanticist_strength = 15;
Q.romanticist_dissent = 15;
Q.reformist_strength = 25;
Q.reformist_dissent = 0;

// factions split
Q.unions_independent = 0;
Q.centrists_resign = 0;
Q.left_split = 0;
Q.reformists_resigned = 0;

// inter-party relations
Q.mnlp_relation = 55;
Q.plfm_relation = 25;
Q.ffm_relation = 15;
Q.p_relation = 35;
Q.pec_relation = 10;

Q.mnlp_ideology = "Market Liberalism";
Q.mnlp_marsism = "Moderate Marsism";
Q.plfm_ideology = "Marxism-Leninism-Maoism";
Q.plfm_marsism = "Radical Marsism";
Q.ffm_ideology  = "National Syndicalism";
Q.ffm_marsism = "Radical Marsism";
Q.pec_ideology  = "Colonial Liberalism";
Q.pec_marsism = "Earthism";
Q.p_ideology  = "Accellerationism";
Q.p_marsism = "Marsism";

// relations with unions

Q.gclm_union_relation = 70;
Q.mfpe_union_relation = 50;
Q.pma_union_relation = 25;

// The state of the country

// national ideology - on a binary scale
// marsism (+) vs earthism (-)
Q.marsism = 40;
// socialism (+) vs capitalism (-)
Q.socialism = 25;
// rule of law (+) vs rule of strength (-)
Q.rol = 60;

Q.budget = 3;
Q.budget_growth = 2;

// Proportion of different social groups 
//This is their political representation. Not their actual numbers!!! Should the system become more democratic, these are bound to change
Q.miners = 5
Q.technicians = 20
Q.researchers = 5
Q.bureaucrats = 15
Q.indipendent_capitalist_class = 15
Q.capitalist_class = 30

Q.classes = ['miners', 'technicians', 'researchers', 'bureaucrats', 'indipendent_capitalist_class', 'capitalist_class'];
Q.parties = ['spm', 'mnlp', 'pec', 'plfm', 'ffm', 'p'];

// Support for party by social group
// they don't have to sum to 100 since the electoral calculations will be normalized.
Q.miners_spm = 40;
Q.miners_plfm = 40;
Q.miners_ffm = 10;
Q.miners_mnlp = 0;
Q.miners_pec = 0;
Q.miners_p = 0;
Q.miners_other = 10;

Q.technicians_spm = 60;
Q.technicians_plfm = 5;
Q.technicians_ffm = 5;
Q.technicians_mnlp = 20;
Q.technicians_pec = 0;
Q.technicians_p = 0;
Q.technicians_other = 10;

Q.researchers_spm = 35;
Q.researchers_plfm = 0;
Q.researchers_ffm = 0;
Q.researchers_mnlp = 35;
Q.researchers_pec = 10;
Q.researchers_p = 10;
Q.researchers_other = 10;

Q.bureaucrats_spm = 15;
Q.bureaucrats_plfm = 0;
Q.bureaucrats_ffm = 0;
Q.bureaucrats_mnlp = 40;
Q.bureaucrats_pec = 30;
Q.bureaucrats_p = 5;
Q.bureaucrats_other = 10;

Q.indipendent_capitalist_class_spm = 5;
Q.indipendent_capitalist_class_plfm = 0;
Q.indipendent_capitalist_class_ffm = 0;
Q.indipendent_capitalist_class_mnlp = 60;
Q.indipendent_capitalist_class_pec = 20;
Q.indipendent_capitalist_class_p = 5;
Q.indipendent_capitalist_class_other = 10;

Q.capitalist_class_spm = 0;
Q.capitalist_class_plfm = 0;
Q.capitalist_class_ffm = 0;
Q.capitalist_class_mnlp = 5;
Q.capitalist_class_pec = 95;
Q.capitalist_class_p = 0;
Q.capitalist_class_other = 0;


// Current Martian Parliament composition
Q.spm_r = 22;
Q.plfm_r = 3;
Q.ffm_r = 2;
Q.mnlp_r = 20;
Q.p_r = 1;
Q.pec_r = 49;
